
<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold"><%= @account.name %></h1>
  <div class="flex space-x-2">
    <%= render Ui::ButtonComponent.new(href: accounts_path, label: t("accounts.show.back_to_accounts"), variant: "ghost") do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
      </svg>
    <% end %>
    <% if @account.account_memberships.find_by(user: Current.user)&.owner? %>
      <%= render Ui::ButtonComponent.new(href: edit_account_path(@account), label: "Edit", variant: "outline") %>
      <%= render Ui::ButtonComponent.new(
        href: account_account_memberships_path(@account),
        label: t("accounts.show.manage_members"),
        variant: "default"
      ) %>
    <% end %>
  </div>
</div>

<h2 class="text-xl font-semibold mb-4"><%= t("accounts.show.members") %></h2>
<table class="min-w-full bg-card border mb-6">
  <thead>
    <tr class="bg-muted">
      <th class="px-4 py-2 text-left"><%= t("shared.name") %></th>
      <th class="px-4 py-2 text-left"><%= t("shared.email") %></th>
      <th class="px-4 py-2 text-left"><%= t("shared.role") %></th>
    </tr>
  </thead>
  <tbody>
    <% @members.each do |membership| %>
      <tr class="border-t">
        <td class="px-4 py-2"><%= membership.user.name %></td>
        <td class="px-4 py-2"><%= membership.user.email_address %></td>
        <td class="px-4 py-2"><%= membership.role.capitalize %></td>
      </tr>
    <% end %>
  </tbody>
</table>

