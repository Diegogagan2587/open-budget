<%
  filter_params = local_assigns[:filter_params] || {}
  projects = local_assigns.fetch(:projects)
  project_options = projects.map { |project| [project.name, project.id] }
  status_options = Projects::Task::STATUSES.map { |status| [status.humanize, status] }
  priority_options = Projects::Task::PRIORITIES.map { |priority| [priority.humanize, priority] }
%>

<%= form_with model: task, url: task_task_path(task, filter_params), method: :patch, local: true, scope: :task, data: { turbo: true } do |form| %>
  <% if task.errors.any? %>
    <div class="mb-6 rounded-lg border border-destructive/20 bg-destructive/10 p-4">
      <h2 class="mb-2 text-sm font-semibold text-destructive"><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</h2>
      <ul class="list-inside list-disc text-sm text-destructive">
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-6">
    <%= form.label :title, "Task Title", class: "mb-2 block text-sm font-semibold text-foreground" %>
    <%= form.text_field :title, class: "w-full rounded-lg border border-input bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div class="mb-6">
    <%= form.label :description, "Description", class: "mb-2 block text-sm font-semibold text-foreground" %>
    <%= form.text_area :description, class: "min-h-28 w-full rounded-lg border border-input bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary", rows: 5 %>
  </div>

  <div class="mb-6 grid grid-cols-1 gap-6 md:grid-cols-3">
    <div>
      <label class="mb-2 block text-sm font-semibold text-foreground">Status</label>
      <%= render Ui::SelectComponent.new(name: "task[status]", options: status_options, selected: task.status) %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-semibold text-foreground">Priority</label>
      <%= render Ui::SelectComponent.new(name: "task[priority]", options: priority_options, selected: task.priority) %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-semibold text-foreground">Project</label>
      <%= render Ui::SelectComponent.new(name: "task[project_id]", options: project_options, selected: task.project_id, include_blank: "Unassigned") %>
    </div>
  </div>

  <div class="mb-6">
    <%= form.label :due_date, "Due Date", class: "mb-2 block text-sm font-semibold text-foreground" %>
    <%= form.date_field :due_date, class: "w-full rounded-lg border border-input bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
    <button type="button" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-[color,box-shadow,border-color,background-color] outline-none disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 shrink-0 focus-visible:border-ring focus-visible:ring-ring/40 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive border border-input bg-card text-foreground shadow-sm hover:bg-muted/60 hover:text-foreground h-9 px-4 py-2 has-[>svg]:px-3" onclick="document.dispatchEvent(new CustomEvent('drawer:close'))">
      Cancel
    </button>
    <%= form.submit "Update Task", class: "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-[color,box-shadow,border-color,background-color] outline-none disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 shrink-0 focus-visible:border-ring focus-visible:ring-ring/40 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive border border-transparent bg-primary text-primary-foreground shadow-sm hover:bg-primary/92 h-9 px-4 py-2 has-[>svg]:px-3" %>
  </div>
<% end %>
