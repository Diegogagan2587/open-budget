<%
  filter_params = local_assigns[:filter_params] || {}
%>
<%= turbo_frame_tag dom_id(task) do %>
  <div class="rounded-xl border border-border bg-card p-4 shadow-sm transition-shadow hover:shadow-md">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-base font-semibold text-foreground"><%= task.title %></h3>
          <%= render StatusBadgeComponent.new(status: task.status, type: :status) %>
          <%= render StatusBadgeComponent.new(status: task.priority, type: :priority) %>
          <span class="rounded-full bg-muted px-2 py-1 text-xs text-foreground"><%= task.project_name %></span>
        </div>

        <% if task.description.present? %>
          <p class="mt-2 text-sm text-muted-foreground"><%= truncate(task.description, length: 180) %></p>
        <% end %>

        <div class="mt-3 flex flex-wrap gap-3 text-xs text-muted-foreground">
          <span><%= task.task_number %></span>
          <% if task.due_date.present? %>
            <span>Due <%= l(task.due_date, format: :short) %></span>
          <% end %>
          <% if task.completed_at.present? %>
            <span>Completed <%= l(task.completed_at, format: :short) %></span>
          <% end %>
        </div>
      </div>

      <div class="flex flex-col gap-3 md:w-[18rem]">
        <%= form_with model: task, url: task_task_path(task, filter_params), method: :patch, local: true, data: { controller: "autosubmit" } do %>
          <div>
            <label class="mb-1 block text-xs font-medium text-muted-foreground">Status</label>
            <%= render Ui::SelectComponent.new(
              name: "task[status]",
              options: Projects::Task::STATUSES.map { |status| [status.humanize, status] },
              selected: task.status,
              data: { controller: "autosubmit", action: "change->autosubmit#submit" }
            ) %>
          </div>
        <% end %>

        <div class="flex flex-wrap gap-2">
          <button type="button" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-[color,box-shadow,border-color,background-color] outline-none disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 shrink-0 focus-visible:border-ring focus-visible:ring-ring/40 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive border border-input bg-card text-foreground shadow-sm hover:bg-muted/60 hover:text-foreground h-8 rounded-md gap-1.5 px-3 has-[>svg]:px-2.5" onclick="window.drawerOpen('<%= j(edit_task_task_path(task, filter_params)) %>')">
            Edit
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>
