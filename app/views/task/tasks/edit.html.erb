<div class="mb-6">
  <p class="text-sm text-muted-foreground"><%= @task.task_number %></p>
</div>

<div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
  <%= render "form", task: @task, projects: @projects, filter_params: params.permit(:project_id, :status, :priority).to_h.symbolize_keys.compact_blank %>
</div>
