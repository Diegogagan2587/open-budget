<%= form_with model: @job_application, url: (@job_application.persisted? ? career_job_application_path(@job_application) : career_job_applications_path), class: "space-y-6" do |f| %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Company name</label>
      <%= text_field_tag "career_job_application[company_name]", @job_application.company&.name, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Role title</label>
      <%= f.text_field :role_title, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground", required: true %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Job URL</label>
      <%= f.url_field :job_url, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Source</label>
      <%= f.text_field :source, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Status</label>
      <%= f.select :status, Career::JobApplication::STATUSES.map { |status| [status.humanize, status] }, {}, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Found on</label>
      <%= f.date_field :found_on, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Applied on</label>
      <%= f.date_field :applied_on, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Priority</label>
      <%= f.select :priority, Career::JobApplication.priorities.keys.map { |key| [key.humanize, key] }, {}, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Remote type</label>
      <%= f.text_field :remote_type, placeholder: "remote, hybrid, onsite", class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Location</label>
      <%= f.text_field :location, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Salary min</label>
      <%= f.number_field :salary_min, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Salary max</label>
      <%= f.number_field :salary_max, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Currency</label>
      <%= f.text_field :currency, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>

    <div>
      <label class="mb-2 block text-sm font-medium text-foreground">Fit score (0-100)</label>
      <%= f.number_field :fit_score, min: 0, max: 100, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    </div>
  </div>

  <div>
    <label class="mb-2 block text-sm font-medium text-foreground">Job description</label>
    <%= f.text_area :job_description, rows: 5, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
  </div>

  <div>
    <label class="mb-2 block text-sm font-medium text-foreground">Notes</label>
    <%= f.text_area :notes, rows: 4, class: "w-full rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-primary-foreground" %>
    <%= link_to "Cancel", career_job_applications_path, class: "inline-flex items-center justify-center rounded-md border border-input px-4 py-2" %>
  </div>
<% end %>
