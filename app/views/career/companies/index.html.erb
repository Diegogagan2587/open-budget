<div class="container mx-auto px-4 py-8">
  <h1 class="mb-6 text-2xl font-bold text-foreground">Career companies</h1>

  <%= form_with model: Career::Company.new, url: career_companies_path, class: "mb-6 grid grid-cols-1 gap-3 rounded-lg border border-border bg-card p-4 md:grid-cols-4" do |f| %>
    <%= f.text_field :name, placeholder: "Company name", required: true, class: "rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    <%= f.url_field :website_url, placeholder: "Website URL", class: "rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    <%= f.url_field :linkedin_url, placeholder: "LinkedIn URL", class: "rounded-md border border-input bg-background px-3 py-2 text-foreground" %>
    <%= f.submit "Add company", class: "inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-primary-foreground" %>
  <% end %>

  <div class="space-y-2">
    <% @companies.each do |company| %>
      <div class="rounded-lg border border-border bg-card p-4">
        <p class="font-medium"><%= company.name %></p>
        <p class="text-sm text-muted-foreground"><%= company.website_url.presence || "No website" %></p>
      </div>
    <% end %>
    <% if @companies.empty? %>
      <p class="text-sm text-muted-foreground">No companies yet.</p>
    <% end %>
  </div>
</div>
