<%= form_with url: quick_add_create_income_path, local: false, data: { turbo: true } do |f| %>
  <div class="space-y-3">
    <div>
      <label class="block text-sm font-medium text-foreground mb-1">Description</label>
      <%= render Ui::InputComponent.new(name: "income[description]", placeholder: "Salary", value: @income&.description) %>
    </div>

    <div>
      <label class="block text-sm font-medium text-foreground mb-1">Amount</label>
      <%= render Ui::InputComponent.new(name: "income[expected_amount]", type: "number", placeholder: "0.00", value: @income&.expected_amount) %>
    </div>

    <div>
      <label class="block text-sm font-medium text-foreground mb-1">Date</label>
      <%= render Ui::InputComponent.new(name: "income[expected_date]", type: "date", value: @income&.expected_date || Date.today) %>
    </div>

    <div>
      <label class="block text-sm font-medium text-foreground mb-1">Destination account</label>
      <%= render Ui::SelectComponent.new(
        name: "income[destination]",
        options: (
          (Current.account&.financial_accounts || []).map { |a| ["Asset: #{a.name}", "asset_#{a.id}"] } +
          (Current.account&.financial_liabilities || []).map { |l| ["Liability: #{l.name}", "liability_#{l.id}"] }
        ),
        selected: nil,
        include_blank: "Select destination"
      ) %>
    </div>

    <div class="flex justify-end gap-2 pt-2">
      <%= render Ui::ButtonComponent.new(label: "Create Income", variant: :default, type: "submit") %>
    </div>
  </div>
<% end %>
