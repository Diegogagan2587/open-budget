<button
  type="button"
  data-action="click->sidebar#toggle"
  data-sidebar-target="trigger"
  data-trigger-variant="<%= variant %>"
  aria-expanded="false"
  aria-label="<%= t("nav.menu_open", default: "Toggle Sidebar") %>"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sidebar-ring disabled:pointer-events-none disabled:opacity-50"
>
  <span class="sr-only"><%= t("nav.toggle_sidebar", default: "Toggle sidebar") %></span>
  <% if menu_variant? %>
    <span class="relative block h-4 w-5" aria-hidden="true">
      <span class="hamburger-line hamburger-line-top absolute left-0 top-0 block h-0.5 w-5 rounded-full bg-current"></span>
      <span class="hamburger-line hamburger-line-middle absolute left-0 top-[7px] block h-0.5 w-5 rounded-full bg-current"></span>
      <span class="hamburger-line hamburger-line-bottom absolute left-0 top-[14px] block h-0.5 w-5 rounded-full bg-current"></span>
    </span>
  <% else %>
    <svg class="h-5 w-5 transition-transform duration-200 ease-linear" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <rect x="3" y="4" width="18" height="16" rx="2" stroke-width="1.8" />
      <path stroke-width="1.8" stroke-linecap="round" d="M9 4v16" />
      <path stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="m15 9-3 3 3 3" />
    </svg>
  <% end %>
</button>
