<div class="md:hidden">
  <div class="fixed inset-x-0 bottom-0 z-50">
    <div class="bg-background rounded-t-lg shadow-lg w-full h-[90vh] overflow-auto">
      <div class="p-4 border-b bg-muted">
        <% if @title.present? %>
          <h3 class="text-lg font-semibold"><%= @title %></h3>
        <% end %>
        <% if @description.present? %>
          <p class="text-sm text-muted-foreground"><%= @description %></p>
        <% end %>
      </div>
      <div class="p-4">
        <%= content %>
      </div>
    </div>
  </div>
</div>
