<div class="<%= card_classes %>">
  <% if show_header? %>
    <div class="flex flex-col gap-1.5 pb-4">
      <% if @title.present? %>
        <h2 class="text-lg font-semibold leading-none tracking-tight text-card-foreground"><%= @title %></h2>
      <% end %>
      <% if @description.present? %>
        <p class="text-sm text-muted-foreground"><%= @description %></p>
      <% end %>
    </div>
  <% end %>
  <% shadcn_line = @preset.to_s == "shadcn-line" %>
  <div
    class="min-w-0"
    data-controller="charts"
    data-charts-config-value="<%= h(chart_config_json) %>"
    data-charts-preset-value="<%= h(@preset) %>"
    <% if shadcn_line %>
    data-charts-legend-aria-label-value="<%= h(@legend_aria_label) %>"
    <% end %>>
    <div class="<%= @wrapper_class %>">
      <canvas class="<%= @canvas_class %>" data-charts-target="canvas"></canvas>
    </div>
    <% if shadcn_line %>
    <div
      class="mt-3 flex max-h-[min(50vh,22rem)] flex-col gap-2 overflow-y-auto overflow-x-hidden overscroll-y-contain sm:mt-4 sm:max-h-none sm:flex-row sm:flex-wrap sm:gap-x-3 sm:gap-y-2 sm:overflow-visible"
      data-charts-target="legend"></div>
    <% end %>
  </div>
</div>
