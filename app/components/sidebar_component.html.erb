<div data-slot="sidebar-wrapper" class="group/sidebar-wrapper flex h-full w-full flex-col" data-side="left" data-collapsible="icon">
  <aside data-slot="sidebar" data-sidebar-target="sidebar" data-side="left" data-state="expanded" data-collapsible="icon" data-variant="sidebar" class="fixed inset-y-0 z-30 hidden h-svh w-[var(--sidebar-width)] flex-col overflow-y-auto border-r border-sidebar-border bg-sidebar text-sidebar-foreground transition-[left,right,width] duration-200 ease-linear md:flex data-[side=left]:left-0 data-[side=right]:right-0">
    <%= content %>
  </aside>

  <div data-slot="sidebar-mobile" class="md:hidden">
    <div data-sidebar-target="backdrop" class="fixed inset-0 z-40 hidden bg-black/50 opacity-0 transition-opacity duration-200" aria-hidden="true" data-action="click->sidebar#close"></div>
    <div data-sidebar-target="panel" data-side="left" class="fixed inset-y-0 left-0 z-50 w-[var(--sidebar-width-mobile)] -translate-x-full overflow-y-auto border-r border-sidebar-border bg-sidebar text-sidebar-foreground shadow-2xl transition-transform duration-200 ease-out data-[side=right]:left-auto data-[side=right]:right-0">
      <%= content %>
    </div>
  </div>
</div>
