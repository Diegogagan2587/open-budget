<section class="mb-6 rounded-xl border border-border bg-card p-4 text-card-foreground shadow-sm">
  <%= form_with url: @url, method: :get, local: true, scope: nil, class: form_grid_class do %>
    <div class="flex flex-col gap-1.5">
      <%= label_tag "from", t("reports.period_from"), class: "text-sm font-medium text-muted-foreground" %>
      <%= render Ui::InputComponent.new(
            name: "from",
            id: "from",
            type: "date",
            value: from_value
          ) %>
    </div>

    <div class="flex flex-col gap-1.5">
      <%= label_tag "to", t("reports.period_to"), class: "text-sm font-medium text-muted-foreground" %>
      <%= render Ui::InputComponent.new(
            name: "to",
            id: "to",
            type: "date",
            value: to_value
          ) %>
    </div>

    <% if show_period? %>
      <div class="flex flex-col gap-1.5">
        <%= label_tag "period", t("reports.grouped_by"), class: "text-sm font-medium text-muted-foreground" %>
        <%= render Ui::SelectComponent.new(
              name: "period",
              id: "period",
              options: @period_options,
              selected: selected_period
            ) %>
      </div>
    <% end %>

    <div class="flex flex-col gap-2 sm:flex-row md:justify-end">
      <%= render Ui::ButtonComponent.new(label: t("reports.apply"), type: "submit", css_class: "w-full sm:w-auto") %>
      <%= render Ui::ButtonComponent.new(
            label: t("reports.reset_filters"),
            href: reset_url,
            variant: :outline,
            css_class: "w-full sm:w-auto"
          ) %>
    </div>
  <% end %>

  <% if active_filters.any? %>
    <div class="mt-3 flex flex-wrap items-center gap-2 border-t border-border pt-3">
      <span class="text-xs font-medium uppercase tracking-wide text-muted-foreground"><%= t("reports.active_filters") %></span>
      <% active_filters.each do |filter| %>
        <%= render Ui::BadgeComponent.new(href: filter[:clear_url], variant: :secondary, css_class: "hover:bg-secondary/80") do %>
          <span><%= "#{filter[:label]}: #{filter[:value]}" %></span>
          <span class="text-muted-foreground" aria-hidden="true">&times;</span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>
